{
	admin off
	auto_https off
}

:8080 {
	basic_auth {
		{$APP_ACCESS_USERNAME} {$APP_ACCESS_PASSWORD_HASH}
	}

	header {
		Content-Security-Policy "default-src 'self'; connect-src 'self'; font-src 'self'; img-src 'self' data:; style-src 'self'; script-src 'self'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'"
		Referrer-Policy "no-referrer"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
		-Server
	}

	route {
		@internal path /internal/* /api/tasks* /api/mcp* /api/extensions* /ws*
		respond @internal 404

		handle /api/v1/* {
			reverse_proxy app:8000 {
				header_up X-CF-Actor {$APP_ACCESS_USERNAME}
				header_up X-CF-Actor-Role human
			}
		}

		handle {
			root * /srv
			try_files {path} /index.html
			file_server
		}
	}
}

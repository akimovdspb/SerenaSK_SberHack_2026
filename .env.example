# Non-secret Compose defaults. Secret-bearing values intentionally stay empty.
COMPOSE_PROJECT_NAME=communication-factory
LOCAL_UID=1000
LOCAL_GID=1000
GATEWAY_HOST_BIND=127.0.0.1
GATEWAY_HOST_PORT=8080
APP_ENV=development
DEFAULT_EXECUTION_MODE=deterministic_template
DATABASE_URL=sqlite:////data/factory.db
ARTIFACTS_DIR=/data/artifacts

APP_ACCESS_PASSWORD_HASH=
APP_ACCESS_USERNAME=
MCP_SHARED_TOKEN=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OUROBOROS_NETWORK_PASSWORD=

# Canonical VPS sources remain outside the checkout.
OPENAI_API_KEY_HOST_PATH=/home/dmitry/secrets/communication-factory/OPENAI_API_KEY.txt
PROVIDER_API_KEY_HOST_PATH=/home/dmitry/secrets/communication-factory/OPENAI_API_KEY.txt
PROVIDER_API_KEY_CONTAINER_PATH=/run/secrets/openai_api_key
OPERATOR_LIMITS_HOST_PATH=/home/dmitry/secrets/communication-factory/operator-limits.yaml
OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
OPERATOR_LIMITS_FILE=/run/config/operator-limits.yaml

TOTAL_BUDGET=20
OUROBOROS_PER_TASK_COST_USD=2
OUROBOROS_VERSION=v6.61.4
OUROBOROS_SHA=a00d51dd414f794d830cacf7da760061e442fa88
OUROBOROS_MODEL=openai::gpt-5.4-mini
OUROBOROS_MODEL_LIGHT=openai::gpt-5.4-mini
OUROBOROS_MODEL_FALLBACKS=
OUROBOROS_RUNTIME_MODE=light
OUROBOROS_CONTEXT_MODE=low
OUROBOROS_SAFETY_MODE=full
OUROBOROS_TASK_REVIEW_MODE=off
OUROBOROS_ACCEPTANCE_MAX_IMPROVEMENT_PASSES=0
OUROBOROS_POST_TASK_EVOLUTION=false
OUROBOROS_ALLOW_MUTATIVE_SUBAGENTS=false
OUROBOROS_SERVER_HOST=0.0.0.0
OUROBOROS_SERVER_PORT=8765
OUROBOROS_TRUST_NONLOCAL_BIND_WITHOUT_PASSWORD=1
OUROBOROS_SKILLS_REPO_PATH=/skills
OUROBOROS_TOOL_TIMEOUT_SEC=5
OUROBOROS_SAFETY_CALL_TIMEOUT_SEC=5
OUROBOROS_FINALIZATION_GRACE_SEC=2
OUROBOROS_TASK_TIMEOUT_SEC=25
RUN_TERMINAL_DEADLINE_SEC=29

ALLOW_LIVE_EVAL=false
EVAL_MAX_TOKENS=0
EVAL_MAX_COST_USD=0
EVAL_CONCURRENCY=1
ALLOW_GPT54_COMPARATOR=false
COMPARATOR_RUN_ID=
OPENROUTER_ENABLED=false
EVAL_PROVIDER_PROFILE=openai-gpt-5.4-mini
CF_RUNTIME_PROVIDER=openai
LIVE_TASK_TIMEOUT_SECONDS=25
LIVE_RUN_TERMINAL_DEADLINE_SECONDS=29
LIVE_USAGE_EXPECTED_PROVIDER=openai
LIVE_USAGE_REQUIRE_POST_TASK_SUMMARY=true
CONTROLLED_PROVIDER_RETRY_ENABLED=false
CONTROLLED_PROVIDER_RETRY_FAULT_PROFILE=none
OPENROUTER_DAILY_TOKEN_CAP=0
OPENROUTER_MAX_COST_USD=0
ENABLE_P1_CHANNELS=false
